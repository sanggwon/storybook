generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String?
  plan       String      @default("free")
  credits    Int         @default(50)
  createdAt  DateTime    @default(now())
  characters Character[]
  stories    Story[]
}

model Character {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name        String
  role        String
  age         Int?
  personality String?
  sheetUrl    String?
  lockedDesc  String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model Story {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title        String
  state        Json
  status       String   @default("draft")
  storyboardUrl String?
  createdAt    DateTime @default(now())
  scenes       Scene[]
}

model Scene {
  id       String  @id @default(cuid())
  storyId  String
  story    Story   @relation(fields: [storyId], references: [id])
  no       Int
  title    String
  beat     String
  text     String?
  prompt   String?
  imageUrl String?
}

model Job {
  id        String   @id @default(cuid())
  userId    String
  type      String // character | storyboard | page
  refId     String?
  status    String   @default("queued") // queued | running | done | failed
  progress  Int      @default(0)
  resultUrl String?
  error     String?
  createdAt DateTime @default(now())
}
